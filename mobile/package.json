{
  "name": "voisy-mobile",
  "version": "1.0.0",
  "main": "App.js",
  "scripts": {
    "start": "expo start",
    "web": "npx serve ../ -p 3000 --no-clipboard",
    "dev": "concurrently -n WEB,EXPO -c green,blue \"npm run web\" \"expo start\""
  },
  "dependencies": {
    "expo": "~53.0.0",
    "expo-constants": "~17.0.0",
    "expo-status-bar": "~2.2.0",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-webview": "~13.16.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "concurrently": "^9.1.0",
    "serve": "^14.2.4"
  }
}
